generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  email        String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  services     Service[]
  vehicles     Vehicle[]
}

model Vehicle {
  id           String            @id @default(cuid())
  brand        String
  model        String
  plate        String            @unique
  color        String?
  year         Int?
  status       VehicleStatus     @default(WAITING)
  notes        String?
  customerId   String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  appointments Appointment[]
  services     Service[]
  customer     Customer          @relation(fields: [customerId], references: [id])
  photos       VehiclePhoto[]
  timeline     VehicleTimeline[]
}

model VehicleTimeline {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        TimelineType
  vehicleId   String
  createdAt   DateTime     @default(now())
  vehicle     Vehicle      @relation(fields: [vehicleId], references: [id])
}

model VehiclePhoto {
  id            String       @id @default(cuid())
  imageUrl      String
  type          PhotoType
  vehicleId     String
  serviceId     String?
  createdAt     DateTime     @default(now())
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  service       Service?     @relation(fields: [serviceId], references: [id])
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id])
}

model ServiceTemplate {
  id                   String                @id @default(cuid())
  name                 String
  description          String?
  price                Float
  durationMinutes      Int
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  publicBookingEnabled Boolean               @default(true)
  appointments         Appointment[]
  productUsages        ServiceProductUsage[]
  stockMovements       StockMovement[]
}

model Appointment {
  id                String              @id @default(cuid())
  title             String
  notes             String?
  date              DateTime
  endDate           DateTime?
  status            AppointmentStatus   @default(PENDING)
  customerId        String
  vehicleId         String
  serviceTemplateId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  isPaid            Boolean             @default(false)
  paymentMethod     PaymentMethod?
  groupId           String?
  serviceIndex      Int?
  serviceTotal      Int?
  stockDeductedAt   DateTime?
  customer          Customer            @relation(fields: [customerId], references: [id])
  serviceTemplate   ServiceTemplate?    @relation(fields: [serviceTemplateId], references: [id])
  vehicle           Vehicle             @relation(fields: [vehicleId], references: [id])
  workers           AppointmentWorker[]
  financialSplits   FinancialSplit[]
  stockMovements    StockMovement[]
  photos            VehiclePhoto[]
}

model AppointmentWorker {
  id            String        @id @default(cuid())
  worker        WorkerAccount
  appointmentId String
  createdAt     DateTime      @default(now())
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, worker])
}

model FinancialSplit {
  id            String        @id @default(cuid())
  account       WorkerAccount
  amount        Float
  percentage    Float         @default(0)
  isPaid        Boolean       @default(false)
  paidAt        DateTime?
  appointmentId String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  paidAmount    Float         @default(0)
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, account])
}

model Service {
  id              String         @id @default(cuid())
  title           String
  description     String?
  price           Float
  durationMinutes Int?
  customerId      String
  vehicleId       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  customer        Customer       @relation(fields: [customerId], references: [id])
  vehicle         Vehicle        @relation(fields: [vehicleId], references: [id])
  photos          VehiclePhoto[]
}

model Product {
  id            String                @id @default(cuid())
  name          String
  stock         Float                 @default(0)
  minStock      Float                 @default(0)
  price         Float
  unit          String?
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  initialStock  Float                 @default(0)
  type          ProductType           @default(LIQUID)
  serviceUsages ServiceProductUsage[]
  movements     StockMovement[]
}

model ServiceProductUsage {
  id                String          @id @default(cuid())
  quantity          Float
  serviceTemplateId String
  productId         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  serviceTemplate   ServiceTemplate @relation(fields: [serviceTemplateId], references: [id], onDelete: Cascade)

  @@unique([serviceTemplateId, productId])
}

model StockMovement {
  id                String           @id @default(cuid())
  quantity          Float
  notes             String?
  productId         String
  createdAt         DateTime         @default(now())
  appointmentId     String?
  serviceTemplateId String?
  appointment       Appointment?     @relation(fields: [appointmentId], references: [id])
  product           Product          @relation(fields: [productId], references: [id])
  serviceTemplate   ServiceTemplate? @relation(fields: [serviceTemplateId], references: [id])
}

model Expense {
  id        String          @id @default(cuid())
  title     String
  amount    Float
  category  ExpenseCategory
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model AppSettings {
  id                 String   @id @default("default")
  businessName       String   @default("FamaDetail")
  bookingEnabled     Boolean  @default(true)
  pickupEnabled      Boolean  @default(true)
  openTime           String   @default("09:00")
  closeTime          String   @default("18:00")
  slotStepMinutes    Int      @default(30)
  monday             Boolean  @default(true)
  tuesday            Boolean  @default(true)
  wednesday          Boolean  @default(true)
  thursday           Boolean  @default(true)
  friday             Boolean  @default(true)
  saturday           Boolean  @default(true)
  sunday             Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  fridayCloseTime    String   @default("18:00")
  fridayOpenTime     String   @default("09:00")
  mondayCloseTime    String   @default("18:00")
  mondayOpenTime     String   @default("09:00")
  saturdayCloseTime  String   @default("16:00")
  saturdayOpenTime   String   @default("10:00")
  sundayCloseTime    String   @default("14:00")
  sundayOpenTime     String   @default("10:00")
  thursdayCloseTime  String   @default("18:00")
  thursdayOpenTime   String   @default("09:00")
  tuesdayCloseTime   String   @default("18:00")
  tuesdayOpenTime    String   @default("09:00")
  wednesdayCloseTime String   @default("18:00")
  wednesdayOpenTime  String   @default("09:00")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MBWAY
}

enum WorkerAccount {
  JOAO
  ADRIANA
  FAMADETAIL
}

enum ExpenseCategory {
  PRODUCTS
  MATERIAL
  TOOLS
  MARKETING
  RENT
  OTHER
}

enum ProductType {
  LIQUID
  CHEMICAL
  PASTE
  POWDER
  TOWEL
  PAD
  TOOL
  CONSUMABLE
  OTHER
}

enum VehicleStatus {
  WAITING
  WAITING_BEFORE_PHOTOS
  STARTED
  COMPLETED
  WAITING_AFTER_PHOTOS
}

enum PhotoType {
  BEFORE
  AFTER
}

enum TimelineType {
  CREATED
  STATUS_CHANGED
  BEFORE_PHOTOS
  AFTER_PHOTOS
  SERVICE_STARTED
  SERVICE_FINISHED
  NOTE
}
